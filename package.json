    "stake:simulate": "npm run build && node dist/stake-game.js --slot-engine-run"
  },
  "dependencies": {
    "@slot-engine/core": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24.15.0"
  }
}
