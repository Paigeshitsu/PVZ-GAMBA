{
  "name": "pvz-slot-framework",
  "version": "0.1.0",
  "private": true,
  "main": "dist/stake-game.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node dist/math/engine.test.js",
